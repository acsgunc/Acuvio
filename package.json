{
  "name": "acuvio",
  "version": "0.1.0",
  "description": "Acuvio — a high-performance, Notepad++-style log analyzer for multi-gigabyte log files with live tailing.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:run": "ng test --watch=false --browsers=ChromeHeadless",
    "test:watch": "ng test --watch=true",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "tauri": "tauri",
    "dev": "tauri dev",
    "app:build": "tauri build",
    "app:build:debug": "tauri build --debug",
    "app:installer": "node scripts/build-installer.mjs",
    "app:installer:win": "tauri build --bundles nsis,msi",
    "app:installer:mac": "tauri build --bundles dmg,app",
    "app:installer:linux": "tauri build --bundles deb,rpm,appimage",
    "update": "node scripts/update-deps.mjs",
    "update:check": "node scripts/update-deps.mjs --check",
    "update:latest": "node scripts/update-deps.mjs --latest",
    "fixtures": "node scripts/generate-test-fixtures.mjs",
    "fixtures:large": "node scripts/generate-test-fixtures.mjs test-fixtures --large",
    "sample-log": "node scripts/generate-sample-log.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.0",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "codemirror": "^6.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@tauri-apps/cli": "^2.11.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~6.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true
  }
}
